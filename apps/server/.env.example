ENV=development

# GitHub OAuth Configuration
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Or use inline keys (for production with environment variables)
# JWT_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----
# ...
# -----END RSA PRIVATE KEY-----
# JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----
# ...
# -----END PUBLIC KEY-----

# Root Secret for Refresh Token Encryption (generate a strong random string)
ROOT_SECRET=d09ad0190fab6eaa38d1a87784e9a34948cda54aa73622cc737fc4debc0ec238

# Frontend URL for OAuth callback redirect
FRONTEND_URL=http://localhost:8080

# Server Configuration
HOST=localhost
PORT=3000
