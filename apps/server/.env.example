ENV=development

# GitHub OAuth Configuration
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Or use inline keys (for production with environment variables)
# JWT_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----
# ...
# -----END RSA PRIVATE KEY-----
# JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----
# ...
# -----END PUBLIC KEY-----

# Root Secret for Refresh Token Encryption (generate a strong random string)
ROOT_SECRET=d09ad0190fab6eaa38d1a87784e9a34948cda54aa73622cc737fc4debc0ec238

# Frontend URL for OAuth callback redirect
FRONTEND_URL=http://localhost:8080

# Server Configuration
HOST=localhost
PORT=3000

# P2P Configuration
# WebRTC listening port (UDP)
P2P_WEBRTC_PORT=9090
# WebSocket listening port for browser connectivity (TCP)
P2P_WS_PORT=9091
# Public host for P2P address advertisement
P2P_PUBLIC_HOST=localhost
# Maximum relay reservations allowed
P2P_MAX_RESERVATIONS=100
# Relay reservation TTL in milliseconds (2 hours default)
P2P_RESERVATION_TTL=7200000
# Maximum P2P connections per user
P2P_MAX_CONNECTIONS_PER_USER=5

# TURN Server Configuration (optional, for better NAT traversal)
# TURN_SERVER_URL=turn:turn.example.com:3478
# TURN_SERVER_USERNAME=user
# TURN_SERVER_CREDENTIAL=pass
