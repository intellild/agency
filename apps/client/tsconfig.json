{
  "extends": "./node_modules/@modern-js/tsconfig/base",
  "compilerOptions": {
    "declaration": false,
    "jsx": "preserve",
    "baseUrl": "./",
    "types": ["unplugin-icons/types/react"],
    "lib": ["DOM", "ES2022"],
    "paths": {
      "@/*": ["./src/*"],
      "@shared/*": ["./shared/*"]
    }
  },
  "include": ["src", "shared", "config", "modern.config.ts"],
  "exclude": ["**/node_modules"],
  "references": [
    {
      "path": "../../libs/common"
    }
  ]
}
